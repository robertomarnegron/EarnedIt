# This public repo tracks ONLY the marketing website (docs/).
# The EarnedIt iOS + watchOS source lives in this folder too but is
# intentionally not committed. Remove the /* and !/docs/ lines below
# to start tracking the rest.
/*
!/.gitignore
!/docs/

# --- Xcode (re-activates if the iOS code is ever tracked) ---
build/
DerivedData/
*.xcuserstate
*.xcscmblueprint
xcuserdata/
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# --- Swift Package Manager ---
.build/
.swiftpm/
Packages/
Package.pins
Package.resolved

# --- CocoaPods / Carthage ---
Pods/
Carthage/Build/

# --- macOS ---
.DS_Store

# --- IDE ---
.vscode/
.idea/
